{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": [
      "ES2020"
    ],
    "moduleResolution":"NodeNext",
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts", "src/lib/schedular.ts",

  ]
}